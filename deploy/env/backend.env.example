APP_NAME=Miloševac
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://milosevac.com
FRONTEND_URL=https://milosevac.com

APP_LOCALE=bs
APP_FALLBACK_LOCALE=bs
APP_TIMEZONE=Europe/Sarajevo

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=milosevac
DB_USERNAME=milosevac
DB_PASSWORD=

CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS=info@milosevac.com
MAIL_FROM_NAME="${APP_NAME}"

GOOGLE_ANALYTICS_ID=
GOOGLE_SITE_VERIFICATION=
WEATHER_VERIFY_SSL=true
WORDPRESS_VERIFY_SSL=true
